# =============================================================================
# Placement AI (PAI) — Backend Environment (EXAMPLE / template)
# Copy to .env and fill in real values. Never commit the real .env.
# =============================================================================

# --- AI (DeepSeek) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Web research (SerpAPI) ---
SERPAPI_API_KEY=your_serpapi_key_here

# --- Supabase ---
SUPABASE_PROJECT_ID=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_ANON_KEY=your_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# --- Supabase Auth: JWT verification (asymmetric ES256 via JWKS) ---
SUPABASE_JWKS_URL=https://your_project_ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://your_project_ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_LEGACY_JWT_SECRET=your_legacy_jwt_secret

# --- Supabase Storage ---
SUPABASE_STORAGE_BUCKET=student-documents

# --- Database (Supabase PostgreSQL, async driver) ---
# URL-encode special characters in the password.
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres
DATABASE_URL_POOLER=postgresql+asyncpg://postgres.your_project_ref:your_password@aws-1-<region>.pooler.supabase.com:6543/postgres

# --- Redis (OPTIONAL) ---
# Leave empty to use the in-memory cache fallback.
REDIS_URL=

# --- App ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
